#!/bin/bash
#SBATCH --job-name=weight_trace_gen_resume
#SBATCH --partition=ghx4
#SBATCH --account=bebv-dtai-gh
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=144
#SBATCH --mem=350G
#SBATCH --time=01:00:00
#SBATCH --output=logs/%x_%j.out
#SBATCH --error=logs/%x_%j.err

# Resumption variant of run_generate_weight_traces.slurm: reads
# outputs/schedules/remaining.csv (only the genuinely incomplete combos,
# computed once via a fast bash-level file-count check) instead of looping
# over the full outputs/schedules/summary.csv and relying on
# generate_weight_traces.py's own skip-existing check per combo. That
# per-combo skip still pays real subprocess/conda-activation overhead
# (~12s/combo observed) even when there's nothing to do -- with 126/155
# already done, that overhead alone was projected to eat ~17 minutes of
# the 1h budget before reaching any real remaining work. remaining.csv
# is regenerated by whoever resubmits this (see the one-liner in the
# commit this file was added in, or docs/superpowers/specs/
# 2026-07-18-weight-trace-generation-design.md) -- it is NOT auto-derived
# here, since deriving it requires walking the output tree, which is
# itself the same kind of check we're trying to avoid paying for once
# per combo.

set -uo pipefail
cd /u/yyu9/projects/neuro_cache

export GRB_LICENSE_FILE=/u/yyu9/gurobi.lic
export PYTHONPATH=src
WORKERS=144
SAMPLES=1000
OUT_DIR=/projects/bebv/yyu9/neuro_cache_outputs/weight_traces

if [ ! -f outputs/schedules/remaining.csv ]; then
    echo "ERROR: outputs/schedules/remaining.csv not found -- generate it first"
    echo "(see run_generate_weight_traces_resume.slurm's own header comment)"
    exit 1
fi

while IFS=, read -r arch trace_dir layer; do
    echo "=== $arch / $trace_dir / $layer ==="
    timeout 15m conda run -n base python3 scripts/generate_weight_traces.py \
        --arch "$arch" --trace-dir "$trace_dir" --layer "$layer" \
        --out-dir "$OUT_DIR" \
        --sample-start 0 --sample-count "$SAMPLES" --workers "$WORKERS" < /dev/null \
        || echo "!!! FAILED: $arch/$trace_dir/$layer (exit $?) -- continuing to next combo"
done < <(tail -n +2 outputs/schedules/remaining.csv)
